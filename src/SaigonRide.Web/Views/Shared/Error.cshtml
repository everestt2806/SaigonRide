@model ErrorViewModel
@{ ViewData["Title"] = "Error"; Layout = "_Layout"; }

<div class="row justify-content-center">
    <div class="col-12 col-md-8">
        <div class="card border-danger">
            <div class="card-body text-center">
                <h1 class="h3 mb-3 text-danger">Something went wrong</h1>
                <p class="text-muted">We've logged the issue and will look into it.</p>
                @if (Model.StatusCode.HasValue)
                {
                    <p>Status code: <strong>@Model.StatusCode</strong></p>
                }
                @if (Model.ShowRequestId)
                {
                    <p class="small text-muted">Request ID: <code>@Model.RequestId</code></p>
                }
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Go home</a>
            </div>
        </div>
    </div>
</div>
