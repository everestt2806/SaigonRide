@model (string Icon, string Title, string Description)
<div class="text-center py-5">
    <div class="mb-3">
        <i class="bi @Model.Icon text-muted opacity-50" style="font-size: 3.5rem;"></i>
    </div>
    <h5 class="text-muted fw-medium mb-2">@Model.Title</h5>
    <p class="text-muted small mb-0">@Model.Description</p>
</div>
