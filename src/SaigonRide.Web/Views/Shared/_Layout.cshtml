@using System.Globalization
@inject SaigonRide.Web.Infrastructure.ICurrentUser CurrentUser
@inject Microsoft.Extensions.Localization.IStringLocalizer<SaigonRide.Web.SharedResource> L
@{
    var currentCulture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
}
<!DOCTYPE html>
<html lang="@currentCulture">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>@(ViewData["Title"]) — SaigonRide</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100 bg-light">
    <header>
        <nav class="navbar navbar-expand-lg bg-white border-bottom sticky-top shadow-sm">
            <div class="container-fluid px-4">
                <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <span class="sr-logo-mark"></span><span class="sr-logo">SaigonRide</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link text-secondary" asp-controller="Station" asp-action="Index">@L["NavStations"]</a></li>
                        @if (CurrentUser.IsAuthenticated)
                        {
                            <li class="nav-item"><a class="nav-link text-secondary" asp-controller="Rental" asp-action="Active">@L["NavMyRental"]</a></li>
                            <li class="nav-item"><a class="nav-link text-secondary" asp-controller="Rental" asp-action="History">@L["NavRentalHistory"]</a></li>
                        }
                        @if (CurrentUser.IsAdmin)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-secondary" data-bs-toggle="dropdown" href="#" role="button" aria-expanded="false">@L["NavAdmin"]</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Admin Dashboard</a></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li><a class="dropdown-item" asp-controller="Vehicle" asp-action="Index">@L["NavManageVehicles"] (UC-01)</a></li>
                                    <li><a class="dropdown-item" asp-controller="VehicleCategory" asp-action="Index">@L["NavManageCategories"]</a></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li><a class="dropdown-item" asp-controller="Report" asp-action="Revenue">@L["NavRevenueReport"] (RPT-01)</a></li>
                                    <li><a class="dropdown-item" asp-controller="Report" asp-action="StationUtilisation">@L["NavStationUtilisation"] (RPT-02)</a></li>
                                </ul>
                            </li>
                        }
                    </ul>
                    <div class="d-flex align-items-center gap-3">
                        <span class="dropdown">
                            <a class="text-decoration-none badge rounded-pill text-bg-light p-2 dropdown-toggle" href="#" data-bs-toggle="dropdown" role="button" aria-expanded="false">
                                <i class="bi bi-globe2"></i> @(currentCulture == "vi" ? "🇻🇳 VI" : currentCulture == "ko" ? "🇰🇷 KO" : "🇬🇧 EN")
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                                <li>
                                    <form asp-controller="Account" asp-action="SwitchLang" method="post" class="px-1">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                                        <button type="submit" class="dropdown-item" name="culture" value="en">🇬🇧 English</button>
                                    </form>
                                </li>
                                <li>
                                    <form asp-controller="Account" asp-action="SwitchLang" method="post" class="px-1">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                                        <button type="submit" class="dropdown-item" name="culture" value="vi">🇻🇳 Tiếng Việt</button>
                                    </form>
                                </li>
                                <li>
                                    <form asp-controller="Account" asp-action="SwitchLang" method="post" class="px-1">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                                        <button type="submit" class="dropdown-item" name="culture" value="ko">🇰🇷 한국어</button>
                                    </form>
                                </li>
                            </ul>
                        </span>

                        @if (CurrentUser.IsAuthenticated)
                        {
                            <div class="dropdown">
                                <a class="d-flex align-items-center gap-2 text-decoration-none dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <span class="sr-avatar">@(CurrentUser.Email?.Substring(0, 1).ToUpper() ?? "U")</span>
                                    <span class="fw-medium text-dark d-none d-sm-inline">@(CurrentUser.Email?.Split('@')[0] ?? "User")</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                                    <li><span class="dropdown-item-text text-muted small">@CurrentUser.Email</span></li>
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile"><i class="bi bi-person me-2"></i>@L["Profile"]</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item text-danger"><i class="bi bi-box-arrow-right me-2"></i>@L["Logout"]</button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a class="btn btn-outline-primary btn-sm" asp-controller="Account" asp-action="Login">@L["Login"]</a>
                            <a class="btn btn-primary btn-sm" asp-controller="Account" asp-action="Register">@L["Register"]</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    @{
        var isFullWidth = ViewData["FullWidth"] is true;
    }
    <main role="main" class="@(isFullWidth ? "flex-grow-1" : "container py-4 flex-grow-1")">
        @if (TempData["success"] is string okMsg)
        {
            <div class="@(isFullWidth ? "container" : "")">
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @okMsg
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
            </div>
        }
        @if (TempData["error"] is string errMsg)
        {
            <div class="@(isFullWidth ? "container" : "")">
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @errMsg
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
            </div>
        }
        @if (TempData["info"] is string infoMsg)
        {
            <div class="@(isFullWidth ? "container" : "")">
            <div class="alert alert-info alert-dismissible fade show" role="alert">
                @infoMsg
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="py-5 border-top bg-white mt-auto">
      <div class="container">
        <div class="row g-4">
          <div class="col-12 col-md-4">
            <a asp-controller="Home" asp-action="Index" class="text-decoration-none d-flex align-items-center mb-3">
              <span class="sr-logo-mark"></span><span class="sr-logo">SaigonRide</span>
            </a>
            <p class="text-secondary small mb-0">@L["FooterDesc"]</p>
          </div>
          <div class="col-6 col-md-2">
            <h6 class="small text-uppercase text-secondary mb-3">@L["FooterProduct"]</h6>
            <ul class="list-unstyled small">
                <li class="mb-2"><a asp-controller="Station" asp-action="Index" class="text-decoration-none text-secondary">@L["FooterStations"]</a></li>
                <li class="mb-2"><a href="#" class="text-decoration-none text-secondary">@L["FooterPricing"]</a></li>
                <li class="mb-2"><a href="#" class="text-decoration-none text-secondary">@L["FooterPromo"]</a></li>
            </ul>
          </div>
          <div class="col-6 col-md-2">
            <h6 class="small text-uppercase text-secondary mb-3">@L["FooterSupport"]</h6>
            <ul class="list-unstyled small">
                <li class="mb-2"><a href="#" class="text-decoration-none text-secondary">@L["FooterFAQ"]</a></li>
                <li class="mb-2"><a href="#" class="text-decoration-none text-secondary">@L["FooterContact"]</a></li>
                <li class="mb-2"><a href="#" class="text-decoration-none text-secondary">@L["FooterSafety"]</a></li>
            </ul>
          </div>
          <div class="col-12 col-md-4">
            <h6 class="small text-uppercase text-secondary mb-3">@L["FooterSubscribe"]</h6>
            <div class="input-group">
              <input type="email" class="form-control" placeholder="email@domain.com" />
              <button class="btn btn-primary">@L["FooterSubscribeBtn"]</button>
            </div>
            <small class="text-secondary mt-2 d-block">@L["FooterSpamWarning"]</small>
          </div>
        </div>
        <hr class="my-4" />
        <div class="d-flex flex-wrap justify-content-between align-items-center small text-secondary">
          <div>&copy; @DateTime.Now.Year SaigonRide · Team 521H0148 + 520H0473</div>
          <div class="d-flex gap-3">
            <a class="text-decoration-none text-secondary" href="#">@L["FooterPrivacy"]</a>
            <a class="text-decoration-none text-secondary" href="#">@L["FooterTerms"]</a>
            <a class="text-decoration-none text-secondary" href="#">@L["FooterCookies"]</a>
          </div>
        </div>
      </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
