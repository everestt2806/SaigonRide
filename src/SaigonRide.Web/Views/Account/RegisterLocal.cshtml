@model RegisterLocalViewModel
@{ ViewData["Title"] = "Register — Local Commuter"; }

<div class="row justify-content-center">
    <div class="col-12 col-md-7">
        <h1 class="h4 mb-3">Register — Local Commuter</h1>
        <form asp-action="RegisterLocal" method="post" novalidate>
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none-if-empty"></div>
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" autocomplete="email" maxlength="120" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="FullName" class="form-label"></label>
                    <input asp-for="FullName" class="form-control" maxlength="120" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" maxlength="100" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="ConfirmPassword" class="form-label"></label>
                    <input asp-for="ConfirmPassword" class="form-control" maxlength="100" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="NationalId" class="form-label"></label>
                    <input asp-for="NationalId" class="form-control" maxlength="20" />
                    <span asp-validation-for="NationalId" class="text-danger small"></span>
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="PhoneNumber" class="form-label"></label>
                    <input asp-for="PhoneNumber" class="form-control" maxlength="20" />
                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                </div>
            </div>
            <button type="submit" class="btn btn-primary mt-3">Create account</button>
            <a asp-action="Login" class="btn btn-link mt-3">Already have one?</a>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
