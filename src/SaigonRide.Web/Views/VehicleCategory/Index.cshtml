@model List<VehicleCategory>
@{ ViewData["Title"] = "Vehicle Categories"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Vehicle Categories</h1>
    <a asp-action="Create" class="btn btn-primary">+ Add Category</a>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr><th>Name</th><th>Rate (₫/min)</th><th class="text-end">Actions</th></tr>
        </thead>
        <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td>@c.Name</td>
                    <td>@c.RatePerMinVnd.ToString("N0")</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-outline-secondary btn-sm">Edit</a>
                        <form asp-action="Delete" asp-route-id="@c.Id" method="post" class="d-inline" onsubmit="return confirm('Delete this category?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
