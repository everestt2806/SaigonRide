@model RevenueReportViewModel
@{ ViewData["Title"] = "Revenue Report (RPT-01)"; }

<h1 class="h3 mb-3">Revenue Report by Vehicle Category</h1>

<form method="get" class="card card-body mb-3">
    <div class="row g-3 align-items-end">
        <div class="col-12 col-md-3">
            <label class="form-label">From</label>
            <input type="date" name="from" value="@(Model.FromDate.ToLocalTime().ToString("yyyy-MM-dd"))" class="form-control" />
        </div>
        <div class="col-12 col-md-3">
            <label class="form-label">To</label>
            <input type="date" name="to" value="@(Model.ToDate.ToLocalTime().ToString("yyyy-MM-dd"))" class="form-control" />
        </div>
        <div class="col-12 col-md-3 d-grid">
            <button type="submit" class="btn btn-primary">Apply</button>
        </div>
        <div class="col-12 col-md-3 d-grid">
            <a asp-action="RevenueCsv" asp-route-from="@Model.FromDate" asp-route-to="@Model.ToDate" class="btn btn-outline-secondary">Export CSV</a>
        </div>
    </div>
</form>

<div class="row g-3">
    <div class="col-12 col-lg-7">
        <div class="card">
            <div class="card-body">
                <canvas id="revenueChart" height="220"></canvas>
            </div>
        </div>
    </div>
    <div class="col-12 col-lg-5">
        <div class="card">
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead class="table-light"><tr><th>Category</th><th class="text-end">Trips</th><th class="text-end">Net (₫)</th><th class="text-end">Discount (₫)</th></tr></thead>
                    <tbody>
                        @foreach (var row in Model.Rows)
                        {
                            <tr>
                                <td>@row.CategoryName</td>
                                <td class="text-end">@row.TripCount</td>
                                <td class="text-end">@row.NetRevenue.ToString("N0")</td>
                                <td class="text-end text-success">@row.TotalDiscount.ToString("N0")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr class="fw-bold">
                            <td>Total</td>
                            <td class="text-end">@Model.Rows.Sum(r => r.TripCount)</td>
                            <td class="text-end">@Model.Rows.Sum(r => r.NetRevenue).ToString("N0")</td>
                            <td class="text-end">@Model.Rows.Sum(r => r.TotalDiscount).ToString("N0")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Rows.Select(r => r.CategoryName)));
        const net = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Rows.Select(r => r.NetRevenue)));
        const disc = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Rows.Select(r => r.TotalDiscount)));
        new Chart(document.getElementById('revenueChart'), {
            type: 'bar',
            data: {
                labels,
                datasets: [
                    { label: 'Net Revenue (₫)', data: net, backgroundColor: '#2D5BFF' },
                    { label: 'Discount (₫)', data: disc, backgroundColor: '#FFB627' }
                ]
            },
            options: { responsive: true, scales: { y: { beginAtZero: true } } }
        });
    </script>
}
