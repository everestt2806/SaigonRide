@model CheckoutPreviewViewModel
@{ ViewData["Title"] = "Checkout"; }

<h1 class="h3 mb-3">Checkout</h1>

@if (Model.Fare.DiscountApplied)
{
    <div class="discount-banner mb-3">
        ⚡ Saved <strong>@Model.Fare.Discount.ToString("N0") ₫</strong> — thanks for rebalancing the fleet at <em>@Model.ReturnStationName</em> (@Math.Round(Model.Fare.OccupancyPctAtReturn, 1)% occupancy).
    </div>
}

<div class="card fare-card mb-3">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-12 col-md-6">
                <p class="text-muted mb-1 small">Vehicle</p>
                <p class="h5 mb-0">@Model.Rental.Vehicle?.LicensePlate · @Model.Rental.Vehicle?.Category?.Name</p>
            </div>
            <div class="col-6 col-md-3">
                <p class="text-muted mb-1 small">Duration</p>
                <p class="h5 mb-0">@Model.Fare.DurationMinutes min</p>
            </div>
            <div class="col-6 col-md-3">
                <p class="text-muted mb-1 small">Rate</p>
                <p class="h5 mb-0">@Model.Fare.RatePerMinVnd.ToString("N0") ₫/min</p>
            </div>
        </div>
        <hr />
        <table class="table mb-0">
            <tr><td>Base fare</td><td class="text-end">@Model.Fare.BaseFare.ToString("N0") ₫</td></tr>
            @if (Model.Fare.Discount > 0)
            {
                <tr class="text-success"><td>15% rebalancing discount</td><td class="text-end">−@Model.Fare.Discount.ToString("N0") ₫</td></tr>
            }
            <tr class="fw-bold border-top"><td>Total</td><td class="text-end h5 mb-0">@Model.Fare.TotalFare.ToString("N0") ₫</td></tr>
        </table>
    </div>
</div>

<form asp-action="End" method="post" class="card">
    @Html.AntiForgeryToken()
    <div class="card-body">
        <input type="hidden" name="RentalId" value="@Model.Rental.Id" />
        <input type="hidden" name="ReturnStationId" value="@Model.ReturnStationId" />
        <h2 class="h5 mb-3">Choose payment method</h2>
        @if (Model.Fare.TotalFare < 10000)
        {
            <div class="alert alert-warning small">
                <i class="bi bi-exclamation-triangle"></i>
                VNPay requires a minimum of <strong>10,000 ₫</strong>. Your fare is <strong>@Model.Fare.TotalFare.ToString("N0") ₫</strong>.
                Please ride longer or choose <strong>Cash</strong> payment.
            </div>
        }
        <div class="row g-2">
            @foreach (var item in Model.PaymentMethodOptions)
            {
                var isVnpay = item.Value == "VNPay";
                var disabled = isVnpay && Model.Fare.TotalFare < 10000;
                var icon = item.Value switch
                {
                    "Cash" => "bi-cash-coin",
                    "MoMo" => "bi-phone",
                    "VNPay" => "bi-credit-card-2-front",
                    "PayPal" => "bi-paypal",
                    "ApplePay" => "bi-apple",
                    _ => "bi-wallet2"
                };
                <div class="col-12 col-md-4">
                    <input type="radio" name="PaymentMethod" id="pm-@item.Value" value="@item.Value" class="btn-check" required @(disabled ? "disabled" : "") />
                    <label class="btn @(disabled ? "btn-outline-secondary" : "btn-outline-primary") w-100 d-flex align-items-center justify-content-center gap-2 py-3" for="pm-@item.Value">
                        <i class="bi @icon fs-5"></i>
                        <span>@item.Text @(disabled ? "(min 10,000 ₫)" : "")</span>
                    </label>
                </div>
            }
        </div>
        <button type="submit" class="btn btn-primary mt-3">Pay @Model.Fare.TotalFare.ToString("N0") ₫</button>
        <a asp-action="Active" class="btn btn-outline-secondary mt-3">Back</a>
    </div>
</form>
